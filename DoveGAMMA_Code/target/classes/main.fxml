<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="grafica.ControladorPrincipal"
        style="-fx-background-color: #0a0714;"
        prefWidth="1280" prefHeight="720">

    <left>
        <VBox prefWidth="185" spacing="0"
              style="-fx-background-color: #0e0b1a; -fx-border-color: #2a1040; -fx-border-width: 0 2 0 0;">

            <VBox alignment="CENTER" spacing="4"
                  style="-fx-padding: 24 10 20 10; -fx-background-color: #120d22;">
                <ImageView fitWidth="90" fitHeight="90" preserveRatio="true">
                    <image>
                        <Image url="@icon.png"/>
                    </image>
                </ImageView>
                <HBox alignment="CENTER" spacing="2">
                    <Label text="Dove"
                           style="-fx-font-family: 'Segoe UI'; -fx-font-size: 20; -fx-font-weight: BOLD;
                                  -fx-text-fill: #d4a574; -fx-letter-spacing: 2;"/>
                    <Label text="&#915;"
                           style="-fx-font-family: 'Georgia'; -fx-font-size: 24; -fx-font-weight: BOLD;
                                  -fx-text-fill: #e8c9a8; -fx-effect: dropshadow(three-pass-box, rgba(232,201,168,0.4), 6, 0, 0, 0);"/>
                </HBox>
                <Label text="Gesti&#243;n de Rutas"
                       style="-fx-font-family: 'Segoe UI'; -fx-font-size: 10; -fx-text-fill: #6a4a7a;"/>
            </VBox>

            <Separator style="-fx-background-color: #2a1040;"/>

            <VBox spacing="4" style="-fx-padding: 16 8 8 8;">
                <Button fx:id="btnTogglePanel" text="Mostrar Grafo" alignment="CENTER_LEFT"
                        graphicTextGap="12" onAction="#togglePanelListados"
                        maxWidth="Infinity" prefHeight="44"
                        style="-fx-background-color: #2a1a40; -fx-text-fill: #d4a574; -fx-padding: 0 0 0 16;
                               -fx-font-size: 13; -fx-font-weight: BOLD; -fx-font-family: 'Segoe UI';
                               -fx-background-radius: 8; -fx-cursor: hand;">
                    <graphic>
                        <SVGPath content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                 fill="#d4a574" scaleX="0.8" scaleY="0.8"/>
                    </graphic>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox style="-fx-padding: 8 8 16 8;">
                <Separator style="-fx-background-color: #2a1040;"/>
                <Region prefHeight="10"/>
                <Button text="Limpiar Todo" alignment="CENTER_LEFT" graphicTextGap="12"
                        onAction="#limpiarTodo" maxWidth="Infinity" prefHeight="38"
                        style="-fx-background-color: #3a0a0a; -fx-text-fill: #e8c9a8; -fx-padding: 0 0 0 16;
                               -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                               -fx-background-radius: 8; -fx-cursor: hand;">
                    <graphic>
                        <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                 fill="#e8c9a8" scaleX="0.8" scaleY="0.8"/>
                    </graphic>
                </Button>
            </VBox>
        </VBox>
    </left>

    <!--
        Ahora el center es un StackPane simple.
        panelListados y panelGrafo se pisan uno al otro —
        solo uno está visible a la vez, el que toca.
    -->
    <center>
        <StackPane>

            <!-- ====== PANEL LISTADOS (arranca visible) ====== -->
            <VBox fx:id="panelListados"
                  maxWidth="Infinity" maxHeight="Infinity"
                  style="-fx-background-color: #0e0b1a;">

                <TabPane fx:id="tabPrincipal"
                         tabClosingPolicy="UNAVAILABLE"
                         VBox.vgrow="ALWAYS"
                         style="-fx-background-color: #0e0b1a;">

                    <!-- TAB: PARADAS -->
                    <Tab text="Paradas">
                        <VBox style="-fx-background-color: #0e0b1a; -fx-padding: 8 8 4 8;"
                              VBox.vgrow="ALWAYS" spacing="8">

                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Button text="Agregar" onAction="#toggleFormAgregarParada"
                                        prefHeight="34" graphicTextGap="6"
                                        style="-fx-background-color: #163a16; -fx-text-fill: #90d890;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                                               -fx-font-weight: BOLD; -fx-padding: 0 14 0 10;">
                                    <graphic>
                                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"
                                                 fill="#90d890" scaleX="0.72" scaleY="0.72"/>
                                    </graphic>
                                </Button>
                                <Button text="Modificar" onAction="#toggleFormModParada"
                                        prefHeight="34" graphicTextGap="6"
                                        style="-fx-background-color: #251540; -fx-text-fill: #b890f0;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                                               -fx-font-weight: BOLD; -fx-padding: 0 14 0 10;">
                                    <graphic>
                                        <SVGPath content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                                 fill="#b890f0" scaleX="0.72" scaleY="0.72"/>
                                    </graphic>
                                </Button>
                                <Button text="Eliminar" onAction="#eliminarParadaSeleccionada"
                                        prefHeight="34" graphicTextGap="6"
                                        style="-fx-background-color: #3a1010; -fx-text-fill: #f08080;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                                               -fx-font-weight: BOLD; -fx-padding: 0 14 0 10;">
                                    <graphic>
                                        <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                 fill="#f08080" scaleX="0.72" scaleY="0.72"/>
                                    </graphic>
                                </Button>
                            </HBox>

                            <VBox fx:id="formAgregarParada" spacing="6" visible="false" managed="false"
                                  style="-fx-background-color: #0d0820; -fx-border-color: #2a1a40;
                                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;">
                                <Label text="Nueva Parada"
                                       style="-fx-text-fill: #90d890; -fx-font-weight: BOLD;
                                              -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
                                <HBox spacing="6">
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="ID:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtIdParada" promptText="Ej: P1"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Nombre:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtNombreParada" promptText="Ej: Centro"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="6">
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Pos X:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtXParada" promptText="100"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Pos Y:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtYParada" promptText="100"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="6">
                                    <Button text="Confirmar" onAction="#agregarParada"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #163a16; -fx-text-fill: #90d890;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                    <Button text="Cancelar" onAction="#cancelarFormParada"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #3a1010; -fx-text-fill: #f08080;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>

                            <VBox fx:id="formModParada" spacing="6" visible="false" managed="false"
                                  style="-fx-background-color: #0d0820; -fx-border-color: #3a1a50;
                                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;">
                                <Label text="Modificar Parada"
                                       style="-fx-text-fill: #b890f0; -fx-font-weight: BOLD;
                                              -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
                                <HBox spacing="6">
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="ID:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtModIdParada" editable="false"
                                                   style="-fx-background-color: #160e28; -fx-text-fill: #7a6a8a;
                                                          -fx-background-radius: 5; -fx-border-color: #2a1040;
                                                          -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Nuevo Nombre:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtModNombreParada" promptText="Nuevo nombre"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="6">
                                    <Button text="Guardar" onAction="#modificarParada"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #251540; -fx-text-fill: #b890f0;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                    <Button text="Cancelar" onAction="#cancelarFormParada"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #3a1010; -fx-text-fill: #f08080;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>

                            <TableView fx:id="tablaParadas" VBox.vgrow="ALWAYS"
                                       style="-fx-background-color: #0e0b1a;">
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                <columns>
                                    <TableColumn fx:id="colParadaId"     text="ID" />
                                    <TableColumn fx:id="colParadaNombre" text="Nombre" />
                                    <TableColumn fx:id="colParadaX"      text="Pos X" />
                                    <TableColumn fx:id="colParadaY"      text="Pos Y" />
                                </columns>
                                <placeholder>
                                    <Label text="No hay paradas todavía"
                                           style="-fx-text-fill: #3a2a4a; -fx-font-style: italic; -fx-font-size: 12;"/>
                                </placeholder>
                            </TableView>

                            <VBox fx:id="panelDetallesParada" spacing="6" visible="false" managed="false"
                                  style="-fx-background-color: #12092a; -fx-border-color: #4a2a60;
                                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;">
                                <Label fx:id="lblDetalleParadaTitulo" text="Datos de la Parada Seleccionada"
                                       style="-fx-text-fill: #d4a574; -fx-font-weight: BOLD; -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
                                <Label text="Rutas conectadas directamente (Salidas):" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                <TextArea fx:id="txtDetallesRutasParada" editable="false" prefRowCount="4" wrapText="true"
                                          style="-fx-control-inner-background: #0d0820; -fx-background-color: #0d0820;
                                                 -fx-text-fill: #e8c9a8; -fx-font-family: 'Consolas'; -fx-font-size: 11;
                                                 -fx-border-color: #2a1a40; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                            </VBox>

                        </VBox>
                    </Tab>

                    <!-- TAB: RUTAS -->
                    <Tab text="Rutas">
                        <VBox style="-fx-background-color: #0e0b1a; -fx-padding: 8 8 4 8;"
                              VBox.vgrow="ALWAYS" spacing="8">

                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Button text="Agregar" onAction="#toggleFormAgregarRuta"
                                        prefHeight="34" graphicTextGap="6"
                                        style="-fx-background-color: #163a16; -fx-text-fill: #90d890;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                                               -fx-font-weight: BOLD; -fx-padding: 0 14 0 10;">
                                    <graphic>
                                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"
                                                 fill="#90d890" scaleX="0.72" scaleY="0.72"/>
                                    </graphic>
                                </Button>
                                <Button text="Modificar" onAction="#toggleFormModRuta"
                                        prefHeight="34" graphicTextGap="6"
                                        style="-fx-background-color: #251540; -fx-text-fill: #b890f0;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                                               -fx-font-weight: BOLD; -fx-padding: 0 14 0 10;">
                                    <graphic>
                                        <SVGPath content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                                 fill="#b890f0" scaleX="0.72" scaleY="0.72"/>
                                    </graphic>
                                </Button>
                                <Button text="Eliminar" onAction="#eliminarRutaSeleccionada"
                                        prefHeight="34" graphicTextGap="6"
                                        style="-fx-background-color: #3a1010; -fx-text-fill: #f08080;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                                               -fx-font-weight: BOLD; -fx-padding: 0 14 0 10;">
                                    <graphic>
                                        <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                 fill="#f08080" scaleX="0.72" scaleY="0.72"/>
                                    </graphic>
                                </Button>
                            </HBox>

                            <VBox fx:id="formAgregarRuta" spacing="6" visible="false" managed="false"
                                  style="-fx-background-color: #0d0820; -fx-border-color: #2a1a40;
                                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;">
                                <Label text="Nueva Ruta"
                                       style="-fx-text-fill: #90d890; -fx-font-weight: BOLD;
                                              -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
                                <HBox spacing="6">
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="ID Origen:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtOrigenRuta" promptText="Ej: P1"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="ID Destino:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtDestinoRuta" promptText="Ej: P2"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="6">
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Tiempo (min):" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtTiempoRuta" promptText="15"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Dist (km):" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtDistanciaRuta" promptText="5.0"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Costo ($):" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtCostoRuta" promptText="50"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                </HBox>
                                <CheckBox fx:id="chkTransbordoRuta" text="Requiere transbordo"
                                          style="-fx-text-fill: #d4a574; -fx-font-size: 11; -fx-font-family: 'Segoe UI';"/>
                                <HBox spacing="6">
                                    <Button text="Confirmar" onAction="#agregarRuta"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #163a16; -fx-text-fill: #90d890;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                    <Button text="Cancelar" onAction="#cancelarFormRuta"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #3a1010; -fx-text-fill: #f08080;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>

                            <VBox fx:id="formModRuta" spacing="6" visible="false" managed="false"
                                  style="-fx-background-color: #0d0820; -fx-border-color: #3a1a50;
                                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;">
                                <Label text="Modificar Ruta"
                                       style="-fx-text-fill: #b890f0; -fx-font-weight: BOLD;
                                              -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
                                <HBox spacing="6">
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Origen:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtModOrigenRuta" editable="false"
                                                   style="-fx-background-color: #160e28; -fx-text-fill: #7a6a8a;
                                                          -fx-background-radius: 5; -fx-border-color: #2a1040;
                                                          -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Destino:" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtModDestinoRuta" editable="false"
                                                   style="-fx-background-color: #160e28; -fx-text-fill: #7a6a8a;
                                                          -fx-background-radius: 5; -fx-border-color: #2a1040;
                                                          -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="6">
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Tiempo (min):" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtModTiempoRuta" promptText="15"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Dist (km):" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtModDistanciaRuta" promptText="5.0"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                                        <Label text="Costo ($):" style="-fx-text-fill: #9a7a5a; -fx-font-size: 10;"/>
                                        <TextField fx:id="txtModCostoRuta" promptText="50"
                                                   style="-fx-background-color: #1e1030; -fx-text-fill: #e8c9a8;
                                                          -fx-prompt-text-fill: #4a3a5a; -fx-background-radius: 5;
                                                          -fx-border-color: #3a1a50; -fx-border-radius: 5; -fx-padding: 6;"/>
                                    </VBox>
                                </HBox>
                                <CheckBox fx:id="chkModTransbordoRuta" text="Requiere transbordo"
                                          style="-fx-text-fill: #d4a574; -fx-font-size: 11; -fx-font-family: 'Segoe UI';"/>
                                <HBox spacing="6">
                                    <Button text="Guardar" onAction="#modificarRuta"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #251540; -fx-text-fill: #b890f0;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                    <Button text="Cancelar" onAction="#cancelarFormRuta"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="30"
                                            style="-fx-background-color: #3a1010; -fx-text-fill: #f08080;
                                                   -fx-font-weight: BOLD; -fx-font-size: 11;
                                                   -fx-background-radius: 6; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>

                            <TableView fx:id="tablaRutas" VBox.vgrow="ALWAYS"
                                       style="-fx-background-color: #0e0b1a;">
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                <columns>
                                    <TableColumn fx:id="colRutaOrigen"     text="Origen" />
                                    <TableColumn fx:id="colRutaDestino"    text="Destino" />
                                    <TableColumn fx:id="colRutaTiempo"     text="Tiempo (min)"/>
                                    <TableColumn fx:id="colRutaDistancia"  text="Dist (km)"/>
                                    <TableColumn fx:id="colRutaCosto"      text="Costo ($)"/>
                                    <TableColumn fx:id="colRutaTransbordo" text="Transbordo" />
                                </columns>
                                <placeholder>
                                    <Label text="No hay rutas todavía"
                                           style="-fx-text-fill: #3a2a4a; -fx-font-style: italic; -fx-font-size: 12;"/>
                                </placeholder>
                            </TableView>

                        </VBox>
                    </Tab>
                </TabPane>

                <Label fx:id="lblMensaje" maxWidth="Infinity" wrapText="true"
                       style="-fx-text-fill: #e8c9a8; -fx-background-color: #2a1a00;
                              -fx-background-radius: 6; -fx-padding: 8;
                              -fx-font-size: 11; -fx-font-family: 'Segoe UI';"
                       visible="false" managed="false"/>

            </VBox>

            <!-- ====== PANEL GRAFO (arranca oculto) ====== -->
            <!--
                El grafo empieza invisible. PanelVisualizacion
                pone sus propios overlays encima del grafo
                (el label de estado + los popups de criterios).
            -->
            <StackPane fx:id="panelGrafo"
                       maxWidth="Infinity" maxHeight="Infinity"
                       visible="false"
                       style="-fx-background-color: #0a0714;">
                <ScrollPane style="-fx-background-color: #0a0714; -fx-background: #0a0714;"
                            fitToWidth="true" fitToHeight="true" pannable="true">
                    <content>
                        <StackPane fx:id="contenedorGrafo" style="-fx-background-color: #0a0714;"/>
                    </content>
                </ScrollPane>
            </StackPane>

        </StackPane>
    </center>

</BorderPane>
